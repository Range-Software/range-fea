; Inno Setup installer script for @PROJECT_HUMAN_NAME@
; Generated by CMake — do not edit directly, modify setup.iss.in instead.

[Setup]
AppId={{AC8A295B-7F64-4798-819D-45DD30BD6C4D}
AppName=@PROJECT_HUMAN_NAME@
AppVersion=@PROJECT_VERSION@
AppPublisher=@PROJECT_AUTHOR@
AppPublisherURL=@PROJECT_WWW@
AppSupportURL=@PROJECT_WWW@
AppUpdatesURL=@PROJECT_WWW@
AppCopyright=Copyright (C) @PROJECT_YEAR@ @PROJECT_AUTHOR@
DefaultDirName={autopf}\@PROJECT_FAMILY_NAME@\@PROJECT_SHORT_NAME@
DefaultGroupName=@PROJECT_FAMILY_NAME@\@PROJECT_SHORT_NAME@
DisableProgramGroupPage=yes
LicenseFile=@ISS_STAGING_DIR@\doc\LICENSE.txt
OutputDir=@ISS_OUTPUT_DIR@
OutputBaseFilename=@CPACK_PACKAGE_FILE_NAME@
SetupIconFile=@ISS_ICON_FILE@
Compression=lzma
SolidCompression=yes
WizardStyle=modern
PrivilegesRequired=lowest
PrivilegesRequiredOverridesAllowed=commandline
ArchitecturesAllowed=x64compatible
ArchitecturesInstallIn64BitMode=x64compatible
UninstallDisplayIcon={app}\bin\@PROJECT_TARGET_NAME@.exe

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Tasks]
Name: "desktopicon"; Description: "{cm:CreateDesktopIcon}"; GroupDescription: "{cm:AdditionalIcons}"; Flags: unchecked

[Files]
Source: "@ISS_STAGING_DIR@\bin\*"; DestDir: "{app}\bin"; Flags: ignoreversion recursesubdirs createallsubdirs
Source: "@ISS_STAGING_DIR@\help\*"; DestDir: "{app}\help"; Flags: ignoreversion recursesubdirs createallsubdirs
Source: "@ISS_STAGING_DIR@\doc\*"; DestDir: "{app}\doc"; Flags: ignoreversion recursesubdirs createallsubdirs
Source: "@ISS_STAGING_DIR@\etc\*"; DestDir: "{app}\etc"; Flags: ignoreversion recursesubdirs createallsubdirs

[Icons]
Name: "{autoprograms}\@PROJECT_FAMILY_NAME@\@PROJECT_SHORT_NAME@\@PROJECT_SHORT_NAME@"; Filename: "{app}\bin\@PROJECT_TARGET_NAME@.exe"; WorkingDir: "{app}"
Name: "{autodesktop}\@PROJECT_SHORT_NAME@"; Filename: "{app}\bin\@PROJECT_TARGET_NAME@.exe"; WorkingDir: "{app}"; Tasks: desktopicon

[Run]
Filename: "{app}\bin\@PROJECT_TARGET_NAME@.exe"; Description: "{cm:LaunchProgram,@PROJECT_HUMAN_NAME@}"; Flags: nowait postinstall skipifsilent
